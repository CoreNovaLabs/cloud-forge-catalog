{
  "ROSTemplateFormatVersion": "2015-09-01",
  "Description": "n8n on Cloud Forge CLI - Aliyun cn-hongkong bootstrap",
  "Parameters": {
    "InstanceType": {
      "Type": "String",
      "Default": "ecs.t6-c1m2.large",
      "AllowedValues": ["ecs.t6-c1m1.large", "ecs.t6-c1m2.large", "ecs.t6-c1m4.large"]
    },
    "ImageId": {
      "Type": "String",
      "Default": "aliyun_3_x64_20G_alibase_20260122.vhd"
    },
    "KeyPairName": { "Type": "String" },
    "VpcId": { "Type": "String" },
    "VSwitchId": { "Type": "String" },
    "AllowedIP": { "Type": "String", "Default": "0.0.0.0/0" },
    "CaddyTlsMode": {
      "Type": "String",
      "Default": "ip-letsencrypt",
      "AllowedValues": ["auto", "ip-letsencrypt", "http", "internal"]
    },
    "DiskSize": { "Type": "Number", "Default": 40, "MinValue": 20, "MaxValue": 500 },
    "DomainName": { "Type": "String", "Default": "" },
    "DnsDomainName": { "Type": "String", "Default": "" },
    "DnsRR": { "Type": "String", "Default": "" },
    "CaddyEmail": { "Type": "String", "Default": "" }
  },
  "Conditions": {
    "UseHttp": { "Fn::Equals": [{ "Ref": "CaddyTlsMode" }, "http"] },
    "HasDomain": {
      "Fn::Not": {
        "Fn::Equals": ["", { "Ref": "DomainName" }]
      }
    },
    "HasDnsDomain": {
      "Fn::Not": {
        "Fn::Equals": ["", { "Ref": "DnsDomainName" }]
      }
    },
    "HasDNS": {
      "Fn::And": ["HasDomain", "HasDnsDomain"]
    }
  },
  "Resources": {
    "N8nSG": {
      "Type": "ALIYUN::ECS::SecurityGroup",
      "Properties": {
        "VpcId": { "Ref": "VpcId" },
        "SecurityGroupName": "cloud-forge-n8n",
        "SecurityGroupIngress": [
          { "IpProtocol": "tcp", "PortRange": "80/80", "SourceCidrIp": "0.0.0.0/0" },
          { "IpProtocol": "tcp", "PortRange": "443/443", "SourceCidrIp": "0.0.0.0/0" },
          { "IpProtocol": "tcp", "PortRange": "22/22", "SourceCidrIp": { "Ref": "AllowedIP" } }
        ]
      }
    },
    "N8nInstance": {
      "Type": "ALIYUN::ECS::Instance",
      "Properties": {
        "ImageId": { "Ref": "ImageId" },
        "InstanceType": { "Ref": "InstanceType" },
        "KeyPairName": { "Ref": "KeyPairName" },
        "VSwitchId": { "Ref": "VSwitchId" },
        "SecurityGroupId": { "Ref": "N8nSG" },
        "SystemDiskSize": { "Ref": "DiskSize" },
        "SystemDiskCategory": "cloud_efficiency",
        "InternetMaxBandwidthOut": 0,
        "UserData": {
          "Fn::Sub": "#!/bin/bash\nset -euxo pipefail\nexport CLOUD_FORGE_CADDY_TLS_MODE=${CaddyTlsMode}\nexport CLOUD_FORGE_DOMAIN_NAME=${DomainName}\nexport CLOUD_FORGE_CADDY_EMAIL=${CaddyEmail}\ncurl -fsSL https://cdn.jsdelivr.net/gh/CoreNovaLabs/cloud-forge-catalog@main/scripts/aliyun/bootstrap-app.sh | bash -s -- n8n\n"
        },
        "Tags": [
          { "Key": "Name", "Value": "cloud-forge-n8n" },
          { "Key": "cloud-forge:app", "Value": "n8n" }
        ]
      }
    },
    "N8nEIP": {
      "Type": "ALIYUN::VPC::EIP",
      "Properties": {
        "Bandwidth": 5,
        "InternetChargeType": "PayByTraffic"
      }
    },
    "N8nEIPAssociation": {
      "Type": "ALIYUN::VPC::EIPAssociation",
      "Properties": {
        "AllocationId": { "Ref": "N8nEIP" },
        "InstanceId": { "Ref": "N8nInstance" }
      }
    },
    "N8nDNS": {
      "Type": "ALIYUN::DNS::DomainRecord",
      "Condition": "HasDNS",
      "DependsOn": ["N8nEIPAssociation"],
      "Properties": {
        "DomainName": { "Ref": "DnsDomainName" },
        "RR": { "Ref": "DnsRR" },
        "Type": "A",
        "Value": { "Fn::GetAtt": ["N8nEIP", "EipAddress"] },
        "TTL": 600
      }
    }
  },
  "Outputs": {
    "ServiceURL": {
      "Description": "Primary endpoint for n8n.",
      "Value": {
        "Fn::If": [
          "HasDomain",
          {
            "Fn::If": [
              "UseHttp",
              { "Fn::Join": ["", ["http://", { "Ref": "DomainName" }]] },
              { "Fn::Join": ["", ["https://", { "Ref": "DomainName" }]] }
            ]
          },
          {
            "Fn::If": [
              "UseHttp",
              { "Fn::Join": ["", ["http://", { "Fn::GetAtt": ["N8nEIP", "EipAddress"] }]] },
              { "Fn::Join": ["", ["https://", { "Fn::GetAtt": ["N8nEIP", "EipAddress"] }]] }
            ]
          }
        ]
      }
    },
    "DomainName": {
      "Description": "Custom domain when configured.",
      "Value": { "Ref": "DomainName" }
    },
    "PublicIP": {
      "Description": "Elastic IP address assigned to the service.",
      "Value": { "Fn::GetAtt": ["N8nEIP", "EipAddress"] }
    },
    "InstanceId": {
      "Description": "Created ECS instance ID.",
      "Value": { "Ref": "N8nInstance" }
    }
  }
}
