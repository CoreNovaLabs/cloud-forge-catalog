{
  "id": "n8n",
  "name": "n8n",
  "desc": "Open-source workflow automation and Zapier alternative",
  "icon": "⚡",
  "category": "automation",
  "tags": ["automation", "workflow", "zapier"],
  "stars": 38000,
  "clouds": ["aws", "aliyun"],
  "version": "1.0.0",
  "min_cli_version": "0.2.0",
  "price": "$8/month",
  "images": {
    "aws": "ami-0b9b527b5a400c0e4",
    "aliyun": "m-0i9j8k7l6m5n4o3p2"
  },
  "templates": {
    "aws": { "path": "apps/n8n/templates/aws.yaml" },
    "aliyun": { "path": "apps/n8n/templates/aliyun.json" }
  },
  "params": {
    "InstanceType": {
      "type": "string",
      "aws": {
        "default": "t3.large",
        "options": ["t3.medium", "t3.large", "t3.xlarge"]
      },
      "aliyun": {
        "default": "ecs.c6.xlarge",
        "options": ["ecs.c6.large", "ecs.c6.xlarge"]
      }
    },
    "LatestAmiId": {
      "type": "string",
      "aws": {
        "default": "ami-0b9b527b5a400c0e4"
      }
    },
    "CaddyTlsMode": {
      "type": "string",
      "aws": {
        "default": "ip-letsencrypt",
        "options": ["ip-letsencrypt", "http", "internal"]
      }
    },
    "DomainName": { "type": "string", "default": "" },
    "HostedZoneId": { "type": "string", "default": "", "aws": { "default": "" } },
    "KeyName": {
      "type": "string",
      "default": "",
      "aws": { "default": "" }
    },
    "KeyPairName": { "type": "string", "aliyun": { "required": true } },
    "DiskSize": {
      "type": "number",
      "aws": { "default": "40" },
      "aliyun": { "default": "40" }
    },
    "VpcId": {
      "type": "string",
      "default": "",
      "aws": { "default": "" },
      "aliyun": { "required": true }
    },
    "SubnetId": {
      "type": "string",
      "default": "",
      "aws": { "default": "" }
    },
    "VSwitchId": { "type": "string", "aliyun": { "required": true } },
    "AllowedIP": { "type": "string", "default": "0.0.0.0/0" }
  }
}
