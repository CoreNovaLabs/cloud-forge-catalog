{
  "id": "nginx",
  "name": "NGINX",
  "desc": "High-performance web server and reverse proxy",
  "icon": "🌐",
  "category": "other",
  "tags": [
    "nginx",
    "aws",
    "aliyun",
    "web-server"
  ],
  "stars": 0,
  "clouds": [
    "aws",
    "aliyun"
  ],
  "version": "1.0.0",
  "min_cli_version": "0.3.0",
  "versions": {
    "default": "1.27-alpine",
    "items": [
      { "version": "1.27-alpine", "verified": true },
      { "version": "1.26-alpine", "verified": false }
    ]
  },
  "tier": "certified",
  "smoke": {
    "health_paths": [
      "/"
    ],
    "wait_seconds": 60
  },
  "price": "free",
  "cost_notice": [
    "Alibaba Cloud defaults to cn-hongkong; choose another supported region in the launcher.",
    "Mainland China regions may fail bootstrap (Docker Hub / catalog CDN reachability).",
    "Custom domains can be configured with Route53 parameters on AWS or Alidns parameters on Alibaba Cloud. DNS propagation and ACME may take several minutes.",
    "First bootstrap may take 8-15 minutes on Aliyun public OS images.",
    "You pay only for cloud resources such as ECS, EIP, disk, and data transfer."
  ],
  "images": {
    "aws": "ami-04cf9ac8716f030d6",
    "aliyun": "aliyun_3_x64_20G_alibase_20260122.vhd"
  },
  "templates": {
    "aws": {
      "path": "apps/nginx/templates/aws.yaml"
    },
    "aliyun": {
      "path": "apps/nginx/templates/aliyun.json"
    }
  },
  "params": {
    "InstanceType": {
      "type": "string",
      "aws": {
        "default": "t3.micro",
        "options": [
          "t3.micro",
          "t3.small",
          "t3.medium"
        ]
      },
      "aliyun": {
        "default": "ecs.t6-c1m1.large",
        "options": [
          "ecs.t6-c1m1.large",
          "ecs.t6-c1m2.large",
          "ecs.t6-c1m4.large"
        ]
      }
    },
    "LatestAmiId": {
      "type": "string",
      "aws": {
        "default": "ami-04cf9ac8716f030d6"
      }
    },
    "ImageId": {
      "type": "string",
      "aliyun": {
        "default": "aliyun_3_x64_20G_alibase_20260122.vhd"
      }
    },
    "CaddyTlsMode": {
      "type": "string",
      "aws": {
        "default": "ip-letsencrypt",
        "options": [
          "auto",
          "ip-letsencrypt",
          "http",
          "internal"
        ]
      },
      "aliyun": {
        "default": "ip-letsencrypt",
        "options": [
          "auto",
          "ip-letsencrypt",
          "http",
          "internal"
        ]
      }
    },
    "DomainName": {
      "type": "string",
      "default": ""
    },
    "HostedZoneId": {
      "type": "string",
      "default": "",
      "aws": {
        "default": ""
      }
    },
    "DnsDomainName": {
      "type": "string",
      "default": "",
      "aliyun": {
        "default": ""
      }
    },
    "DnsRR": {
      "type": "string",
      "default": "",
      "aliyun": {
        "default": ""
      }
    },
    "CaddyEmail": {
      "type": "string",
      "default": ""
    },
    "KeyName": {
      "type": "string",
      "default": "",
      "aws": {
        "default": ""
      }
    },
    "KeyPairName": {
      "type": "string",
      "aliyun": {
        "required": true
      }
    },
    "VpcId": {
      "type": "string",
      "default": "",
      "aws": {
        "default": ""
      },
      "aliyun": {
        "required": true
      }
    },
    "SubnetId": {
      "type": "string",
      "default": "",
      "aws": {
        "default": ""
      }
    },
    "VSwitchId": {
      "type": "string",
      "aliyun": {
        "required": true
      }
    },
    "AllowedIP": {
      "type": "string",
      "default": "0.0.0.0/0"
    }
  }
}
