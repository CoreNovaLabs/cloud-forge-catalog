{
  "id": "{{APP_ID}}",
  "name": "{{APP_NAME}}",
  "desc": "{{APP_DESC}}",
  "icon": "{{APP_ICON}}",
  "category": "{{CATEGORY}}",
  "tags": {{TAGS_JSON}},
  "stars": {{STARS}},
  "tier": "{{TIER}}",
  "clouds": ["aws", "aliyun"],
  "version": "1.0.0",
  "min_cli_version": "0.3.0",
  "price": "free",
  "cost_notice": [
    "Aliyun v1 only supports cn-hongkong.",
    "First bootstrap may take 8-15 minutes on Aliyun public OS images.",
    "You pay only for cloud resources such as ECS, EIP, disk, and data transfer."
  ],
  "smoke": {
    "health_paths": {{SMOKE_HEALTH_PATHS_JSON}},
    "wait_seconds": {{SMOKE_WAIT_SECONDS}}
  },
  "images": {
    "aws": "{{AWS_AMI_DEFAULT}}",
    "aliyun": "{{ALIYUN_IMAGE_DEFAULT}}"
  },
  "templates": {
    "aws": { "path": "apps/{{APP_ID}}/templates/aws.yaml" },
    "aliyun": { "path": "apps/{{APP_ID}}/templates/aliyun.json" }
  },
  "params": {
    "InstanceType": {
      "type": "string",
      "aws": {
        "default": "{{AWS_INSTANCE_DEFAULT}}",
        "options": {{AWS_INSTANCE_OPTIONS_JSON}}
      },
      "aliyun": {
        "default": "{{ALIYUN_INSTANCE_DEFAULT}}",
        "options": {{ALIYUN_INSTANCE_OPTIONS_JSON_ARRAY}}
      }
    },
    "LatestAmiId": {
      "type": "string",
      "aws": { "default": "{{AWS_AMI_DEFAULT}}" }
    },
    "ImageId": {
      "type": "string",
      "aliyun": { "default": "{{ALIYUN_IMAGE_DEFAULT}}" }
    },
    "CaddyTlsMode": {
      "type": "string",
      "aws": {
        "default": "ip-letsencrypt",
        "options": ["ip-letsencrypt", "http", "internal"]
      },
      "aliyun": {
        "default": "ip-letsencrypt",
        "options": ["ip-letsencrypt", "http", "internal"]
      }
    },
    "DomainName": { "type": "string", "default": "" },
    "HostedZoneId": { "type": "string", "default": "", "aws": { "default": "" } },
    "KeyName": { "type": "string", "default": "", "aws": { "default": "" } },
    "KeyPairName": { "type": "string", "aliyun": { "required": true } },
    "DiskSize": {
      "type": "number",
      "aws": { "default": "{{AWS_DISK_DEFAULT}}" },
      "aliyun": { "default": "{{ALIYUN_DISK_DEFAULT}}" }
    },
    "VpcId": {
      "type": "string",
      "default": "",
      "aws": { "default": "" },
      "aliyun": { "required": true }
    },
    "SubnetId": { "type": "string", "default": "", "aws": { "default": "" } },
    "VSwitchId": { "type": "string", "aliyun": { "required": true } },
    "AllowedIP": { "type": "string", "default": "0.0.0.0/0" }{{ADMIN_PASSWORD_PARAM_JSON}}
  }
}
